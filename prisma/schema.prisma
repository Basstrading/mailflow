generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  entities  Entity[]
}

model Entity {
  id                 String        @id @default(cuid())
  name               String
  fromEmail          String
  fromName           String
  replyTo            String?
  isVerified         Boolean       @default(false)
  createdAt          DateTime      @default(now())
  dkimTokens         Json?
  domain             String?
  verificationStatus String?       @default("PENDING")
  userId             String
  campaigns          Campaign[]
  contactLists       ContactList[]
  user               User          @relation(fields: [userId], references: [id])
  warmupConfig       WarmupConfig?
}

model WarmupConfig {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  entityId        String    @unique
  enabled         Boolean   @default(true)
  startDate       DateTime  @default(now())
  dailyLimit      Int       @default(50)
  targetVolume    Int       @default(10000)
  duplicationDays Int       @default(7)
  maxWarmupDays   Int       @default(56)
  totalSent       Int       @default(0)
  lastResetDate   DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

model ContactList {
  id        String     @id @default(cuid())
  name      String
  entityId  String
  createdAt DateTime   @default(now())
  campaigns Campaign[]
  contacts  Contact[]
  entity    Entity     @relation(fields: [entityId], references: [id])
}

model Contact {
  id            String             @id @default(cuid())
  email         String
  firstName     String?
  lastName      String?
  status        ContactStatus      @default(SUBSCRIBED)
  customFields  Json?
  contactListId String
  createdAt     DateTime           @default(now())
  contactList   ContactList        @relation(fields: [contactListId], references: [id])
  emailEvents   EmailEvent[]
  unsubTokens   UnsubscribeToken[]

  @@unique([email, contactListId])
}

model Campaign {
  id            String         @id @default(cuid())
  name          String
  subject       String
  htmlContent   String
  textContent   String?
  entityId      String
  contactListId String
  status        CampaignStatus @default(DRAFT)
  scheduledAt   DateTime?
  sentAt        DateTime?
  totalSent     Int            @default(0)
  createdAt     DateTime       @default(now())
  contactList   ContactList    @relation(fields: [contactListId], references: [id])
  entity        Entity         @relation(fields: [entityId], references: [id])
  emailEvents   EmailEvent[]
}

model EmailEvent {
  id         String    @id @default(cuid())
  campaignId String
  contactId  String
  type       EventType
  metadata   Json?
  timestamp  DateTime  @default(now())
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  contact    Contact   @relation(fields: [contactId], references: [id])
}

model UnsubscribeToken {
  id        String   @id @default(cuid())
  contactId String
  token     String   @unique @default(cuid())
  createdAt DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id])
}

enum UserRole {
  ADMIN
  USER
}

enum ContactStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
}

enum EventType {
  SENT
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
}
